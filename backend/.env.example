APP_ENV=development
APP_NAME=NexGenTeck Contact API
LOG_LEVEL=INFO

DB_HOST=YOUR_HOSTINGER_MYSQL_HOST
DB_PORT=3306
DB_NAME=YOUR_HOSTINGER_DATABASE_NAME
DB_USER=YOUR_HOSTINGER_DATABASE_USER
DB_PASSWORD=YOUR_HOSTINGER_DATABASE_PASSWORD
DB_CONNECT_TIMEOUT=10
DB_SSL_CA=

CORS_ORIGINS=http://localhost:5173,http://localhost:4000,https://nexgenteck.com,https://www.nexgenteck.com,https://nexgenteck.github.io,https://muhammadhasaan82.github.io

SMTP_ENABLED=false
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USERNAME=YOUR_EMAIL_ADDRESS
SMTP_PASSWORD=YOUR_EMAIL_PASSWORD
SMTP_FROM_EMAIL=YOUR_EMAIL_ADDRESS
SMTP_FROM_NAME=NexGenTeck Website
ADMIN_EMAIL=info@nexgenteck.com
