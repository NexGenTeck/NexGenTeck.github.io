# NexGenTeck AI Chatbot Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit real secrets.

# Required: Groq API Key for Llama 3.3
GROQ_API_KEY=your_groq_api_key_here

# Required in production / Hugging Face: secret for POST /reindex
# Also accepted via ADMIN_TOKEN for compatibility with the Gradio Space.
REINDEX_SECRET=generate_a_long_random_token
# ADMIN_TOKEN=

# Website URL (used for source_url metadata and optional live scrape)
WEBSITE_URL=https://nexgenteck.com

# Authoritative source extraction from repository / bundled website_sources
# Prefer true so portfolio/team/partners are ingested without Selenium.
USE_SOURCE_EXTRACTOR=true
# Backward-compatible alias (maps to USE_SOURCE_EXTRACTOR)
USE_TRANSLATION_EXTRACTOR=true

# Secondary live crawl when source extraction is unavailable
ALLOW_LIVE_SCRAPE=false
MAX_SCRAPE_PAGES=100

# Refresh knowledge base on startup when content fingerprint changes
AUTO_REFRESH_ON_STARTUP=true

# Optional override for content root (defaults to monorepo root or bundled sources)
# CONTENT_SOURCE_ROOT=
# PROJECT_ROOT=

# CORS origins (comma-separated)
CORS_ORIGINS=https://nexgenteck.github.io,https://muhammadhasaan82.github.io,https://nexgenteck.com,http://localhost:5173,http://localhost:3000

# Model Configuration
EMBEDDING_MODEL=BAAI/bge-m3
LLM_MODEL=llama-3.3-70b-versatile
# Optional writable model cache (important on Hugging Face / containers)
# MODEL_CACHE_DIR=/data/model-cache
# HF_HOME=/data/hf-home

# RAG Configuration
MAX_CONTEXT_DOCS=8
RELEVANCE_THRESHOLD=1.5
ENABLE_RERANKING=true
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_CANDIDATE_DOCS=30

# LLM Parameters
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=1024

# Qdrant Configuration
# :memory: for ephemeral / HF-like environments
# http://qdrant:6333 for docker-compose production
QDRANT_URL=:memory:
COLLECTION_NAME=nexgenteck_knowledge
